{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/venv/Scripts/python.exe\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/on_edit.py\"",
            "timeout": 90,
            "statusMessage": "Auto-verifying change (manage.py check / consumer + template lint)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/venv/Scripts/python.exe\" \"$CLAUDE_PROJECT_DIR/.claude/hooks/on_stop.py\"",
            "timeout": 300,
            "statusMessage": "Verifying (manage.py check + consumer/template checks + tests)"
          }
        ]
      }
    ]
  }
}
