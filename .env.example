# =============================================================================
# NavAIReceptionist — environment template
#
# Copy this file to `.env` at the repo root and fill in real values.
# NEVER commit `.env` — it stays gitignored.
# EVERY value below is a placeholder/dummy. None of them are real credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
# Django cryptographic signing key — generate a fresh random 50+ char value per environment.
SECRET_KEY=dev-only-insecure-change-me-0000000000000000000000

# Debug mode. Never True in production.
DEBUG=True

# Comma-separated hostnames Django will serve. Add your tunnel host for provider webhooks.
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated origins trusted for CSRF (must include the https tunnel URL in dev).
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Default timezone for the platform; per-tenant and per-contact timezones override it.
TIME_ZONE=UTC


# -----------------------------------------------------------------------------
# Database (MySQL / MariaDB)
# -----------------------------------------------------------------------------
# Database name. Tests use `test_navai_receptionist`.
DB_NAME=navai_receptionist

# Database user.
DB_USER=root

# Database password (empty on a default XAMPP install).
DB_PASSWORD=

# Database host.
DB_HOST=127.0.0.1

# Database port.
DB_PORT=3306


# -----------------------------------------------------------------------------
# Channels / Redis (ASGI channel layer)
# -----------------------------------------------------------------------------
# Redis URL backing CHANNEL_LAYERS — required for live-call groups across workers.
REDIS_URL=redis://127.0.0.1:6379/0


# -----------------------------------------------------------------------------
# Provider mode
# -----------------------------------------------------------------------------
# One of: fake | sandbox | live. `fake` is the default for dev, tests and seeders.
# When this is not `live`, adapters resolve to the fake/sandbox implementation and must
# never reach a real provider — no real call placed, no real SMS sent, no billable API
# call. The live adapter refuses to initialize unless PROVIDER_MODE=live, and live mode
# additionally requires real credentials — missing credentials in live mode is the hard
# failure. Never leave `live` set in a development environment.
PROVIDER_MODE=fake


# -----------------------------------------------------------------------------
# Telephony (Twilio)
# -----------------------------------------------------------------------------
# Twilio account SID.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio auth token — also the key used to verify the X-Twilio-Signature header.
TWILIO_AUTH_TOKEN=00000000000000000000000000000000

# Public base URL that provider webhooks and the media stream point at (ngrok in dev).
# Signature verification compares against this exact public URL.
TWILIO_WEBHOOK_BASE_URL=https://example-tunnel.ngrok-free.app


# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
# LLM provider adapter code.
LLM_PROVIDER=fake

# LLM API key — never logged, never rendered, never in Meta.fields.
LLM_API_KEY=sk-placeholder-000000000000000000000000

# Model identifier used for agent turns.
LLM_MODEL=placeholder-model

# Sampling temperature for agent turns.
LLM_TEMPERATURE=0.4


# -----------------------------------------------------------------------------
# Speech-to-text (STT)
# -----------------------------------------------------------------------------
# STT provider adapter code.
STT_PROVIDER=fake

# STT API key.
STT_API_KEY=stt-placeholder-000000000000000000

# STT model / tier identifier.
STT_MODEL=placeholder-stt

# Default input language hint for transcription.
STT_LANGUAGE=en-US


# -----------------------------------------------------------------------------
# Text-to-speech (TTS)
# -----------------------------------------------------------------------------
# TTS provider adapter code.
TTS_PROVIDER=fake

# TTS API key.
TTS_API_KEY=tts-placeholder-000000000000000000

# Default voice id used when an agent version does not pin one.
TTS_VOICE_ID=placeholder-voice

# Outbound synthesis sample rate in Hz (downsampled to 8 kHz mu-law for the carrier).
TTS_SAMPLE_RATE=24000


# -----------------------------------------------------------------------------
# Storage & retention
# -----------------------------------------------------------------------------
# Bucket/container holding call recordings.
RECORDING_STORAGE_BUCKET=navai-recordings-dev

# Days a recording is retained before the scheduled retention job deletes it.
RECORDING_RETENTION_DAYS=30

# TTL in seconds for the signed URLs handed to the audio player.
RECORDING_SIGNED_URL_TTL=300

# Fernet-style key used to encrypt per-tenant provider credentials at rest.
ENCRYPTION_KEY=placeholder-32-byte-urlsafe-base64-key=


# -----------------------------------------------------------------------------
# Runtime limits
# -----------------------------------------------------------------------------
# Hard ceiling on a single call's duration in seconds (tenant-configurable override).
MAX_CALL_SECONDS=900

# Per-turn tool-iteration cap; exceeding it triggers the spoken fallback.
MAX_TOOL_ITERATIONS=4

# Seconds of caller silence before the runtime ends the call.
IDLE_TIMEOUT_SECONDS=45

# Seconds before any external provider call times out.
PROVIDER_TIMEOUT_SECONDS=10

# Maximum concurrent live calls a single worker will accept.
MAX_CONCURRENT_CALLS=25


# -----------------------------------------------------------------------------
# Cost controls
# -----------------------------------------------------------------------------
# Default per-tenant spend ceiling per billing period, in TENANT_SPEND_CAP_CURRENCY.
TENANT_SPEND_CAP_DEFAULT=100.00

# Currency for the default spend cap.
TENANT_SPEND_CAP_CURRENCY=USD

# Fraction of the spend cap at which the tenant is warned (0.0–1.0).
SPEND_CAP_WARN_THRESHOLD=0.8

# When True, outbound dialing and SMS stop once a tenant's spend cap is reached.
SPEND_CAP_ENFORCE=True
